{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "../../packages/protocol/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "types": ["node", "electron"],
    "paths": {
      "@main/*": ["src/main/*"],
      "@preload/*": ["src/preload/*"],
      "@protocol": ["../../packages/protocol/src/index.ts"],
      "@protocol/*": ["../../packages/protocol/src/*"]
    }
  }
}
